# توکن ربات تلگرام از @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# آیدی عددی کاربران مجاز، با کاما جدا کن (خیلی مهمه، حتما پر کن!)
# آیدیت رو از @userinfobot یا @getidsbot بگیر
ALLOWED_USER_IDS=123456789

# === Cloudflare Workers AI (پروایدر اصلی — پیشنهادی) ===
# اطلاعات اکانت و توکن رو از پنل Cloudflare بگیر:
# https://dash.cloudflare.com → My Profile → API Tokens → Create Token
#   Permissions: Account → Workers AI → Edit
CF_ACCOUNT_ID=your_account_id_here
CF_AI_TOKEN=your_api_token_here

# مدل پیش‌فرض Cloudflare (GLM-5.2 — مدل reasoning فارسی‌زبان)
AI_MODEL=@cf/zai-org/glm-5.2

# مدل پیش‌فرض ربات (کلید داخل MODELS در config.py)
DEFAULT_MODEL_KEY=glm-5.2

# === NVIDIA NIM (fallback — اختیاری) ===
# اگه خالی بذاری، ربات فقط از Cloudflare استفاده می‌کنه.
# اگه پر کنی، ربات اگه Cloudflare خطا بده، میره سراغ NVIDIA.
NVIDIA_API_KEYS=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

DEFAULT_KEY_COOLDOWN_SECONDS=60

# === تنظیمات Agent ===
SHELL_ENABLED=true
SHELL_TIMEOUT_SECONDS=30
PYTHON_TIMEOUT_SECONDS=30
ALLOW_DANGEROUS_COMMANDS=false
MAX_AGENT_ITERATIONS=40
MAX_HISTORY_MESSAGES=20

# === استریم ===
STREAM_ENABLED=true
STREAM_EDIT_MIN_INTERVAL=0.5
STREAM_FIRST_EDIT_DELAY=0.15

# === جستجوی وب ===
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15

# === Cloudflare retry ===
CF_MAX_RETRIES=3
CF_RETRY_DELAY=1.0

# === Storage ===
DB_PATH=/data/bot.db
