# توکن ربات تلگرام از @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# آیدی عددی کاربران مجاز، با کاما جدا کن (خیلی مهمه، حتما پر کن!)
# آیدیت رو از @userinfobot یا @getidsbot بگیر
ALLOWED_USER_IDS=123456789

# === Cloudflare Workers AI ===
# اطلاعات اکانت و توکن‌ها رو از پنل Cloudflare بگیر:
# https://dash.cloudflare.com → My Profile → API Tokens → Create Token
#   Permissions: Account → Workers AI → Edit
#
# چند توکن: اگه چندتا اکانت Cloudflare داری، می‌تونی چند توکن با کاما بذاری.
# ربات به‌صورت sticky بینشون می‌چرخه و اگه یکی rate-limit بخوره، میره سراغ بعدی.
CF_ACCOUNT_ID=8adae8ff813eab68018a78c71d0c54f6
CF_AI_TOKENS=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,cfut_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# مدل پیش‌فرض (کلید داخل MODELS در config.py)
DEFAULT_MODEL_KEY=llama-3.3-70b

# === تنظیمات Agent ===
SHELL_ENABLED=true
SHELL_TIMEOUT_SECONDS=30
PYTHON_TIMEOUT_SECONDS=30
ALLOW_DANGEROUS_COMMANDS=false
MAX_AGENT_ITERATIONS=40
MAX_HISTORY_MESSAGES=20

# === استریم ===
STREAM_ENABLED=true
STREAM_EDIT_MIN_INTERVAL=0.5
STREAM_FIRST_EDIT_DELAY=0.15

# === جستجوی وب ===
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15

# === Cloudflare retry ===
CF_MAX_RETRIES=3
CF_RETRY_DELAY=1.0
CF_KEY_COOLDOWN_SECONDS=30

# === Storage ===
DB_PATH=/data/bot.db
