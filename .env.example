# توکن ربات تلگرام از @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# آیدی عددی کاربران مجاز، با کاما جدا کن (خیلی مهمه، حتما پر کن!)
# آیدیت رو از @userinfobot یا @getidsbot بگیر
ALLOWED_USER_IDS=123456789

# === 9Router (پروایدر OpenCode Free) ===
# اول 9Router رو روی Railway دیپلوی کن: https://railway.com/deploy/9router
# بعد وارد داشبوردش شو، پروایدر OpenCode Free رو Connect کن، و یه API Key بساز.
#
# AI_BASE_URL باید آدرس عمومی 9Router خودت به‌همراه /v1 باشه، مثلا:
# https://my-9router.up.railway.app/v1
#
# چند کلید: اگه چند API Key از 9Router داری، می‌تونی چند تا با کاما بذاری.
# ربات به‌صورت sticky بینشون می‌چرخه و اگه یکی rate-limit بخوره، میره سراغ بعدی.
AI_BASE_URL=https://your-9router-app.up.railway.app/v1
AI_API_KEYS=your_9router_api_key_here

# مدل پیش‌فرض (کلید داخل MODELS در config.py)
DEFAULT_MODEL_KEY=mimo-v2.5

# === تنظیمات Agent ===
SHELL_ENABLED=true
SHELL_TIMEOUT_SECONDS=30
PYTHON_TIMEOUT_SECONDS=30
ALLOW_DANGEROUS_COMMANDS=false
MAX_AGENT_ITERATIONS=40
MAX_HISTORY_MESSAGES=20

# === استریم ===
STREAM_ENABLED=true
STREAM_EDIT_MIN_INTERVAL=0.5
STREAM_FIRST_EDIT_DELAY=0.15

# === جستجوی وب ===
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15

# === 9Router retry ===
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1.0
AI_KEY_COOLDOWN_SECONDS=30

# === Storage ===
DB_PATH=/data/bot.db
